class Creature:
    def __init__(self, strength, defense, next_creature=None):
        if not isinstance(strength, int) or not isinstance(defense, int):
            raise ValueError("strength and defense must be integers")
        if strength <= 0 or defense <= 0:
            raise ValueError("strength and defense must be positive integers")

        self.strength = strength
        self.defense = defense
        self.next_creature = next_creature


class Commander:
    def __init__(self):
        self.hit_points = 40
        self.first_creature = None

    def _validate_chain(self, creature):
        current = creature
        while current is not None:
            if not isinstance(current, Creature):
                raise ValueError("invalid creature in chain")
            if current.strength <= 0 or current.defense <= 0:
                raise ValueError("creature stats must be positive")
            current = current.next_creature

    def _deep_copy_chain(self, creature):
        if creature is None:
            return None

        self._validate_chain(creature)

        copied_head = Creature(creature.strength, creature.defense)
        current_old = creature.next_creature
        current_new = copied_head

        while current_old is not None:
            current_new.next_creature = Creature(
                current_old.strength,
                current_old.defense
            )
            current_new = current_new.next_creature
            current_old = current_old.next_creature

        return copied_head

    def _comes_before(self, c1, c2):
        # Higher defense first
        if c1.defense > c2.defense:
            return True

        # If same defense, higher strength first
        if c1.defense == c2.defense and c1.strength > c2.strength:
            return True

        return False

    def _insert_one_sorted(self, node):
        if self.first_creature is None or self._comes_before(node, self.first_creature):
            node.next_creature = self.first_creature
            self.first_creature = node
            return

        current = self.first_creature
        while current.next_creature is not None and not self._comes_before(node, current.next_creature):
            current = current.next_creature

        node.next_creature = current.next_creature
        current.next_creature = node

    def addCreature(self, creature):
        copied_chain = self._deep_copy_chain(creature)

        current = copied_chain
        while current is not None:
            next_node = current.next_creature
            current.next_creature = None
            self._insert_one_sorted(current)
            current = next_node

    def battle(self, other):
        if not isinstance(other, Commander):
            raise ValueError("battle requires another Commander")

        while self.first_creature is not None and other.first_creature is not None:
            my_creature = self.first_creature
            other_creature = other.first_creature

            # each deals damage to the other
            my_dies = other_creature.strength >= my_creature.defense
            other_dies = my_creature.strength >= other_creature.defense

            # if both survive, battle stops
            if not my_dies and not other_dies:
                return

            # remove dead creatures
            if my_dies:
                self.first_creature = my_creature.next_creature
            if other_dies:
                other.first_creature = other_creature.next_creature

            # if one commander has no creatures left and the other has one remaining,
            # the remaining creature's strength is dealt to the commander
            if self.first_creature is None and other.first_creature is not None:
                self.hit_points -= other.first_creature.strength
                return

            if other.first_creature is None and self.first_creature is not None:
                other.hit_points -= self.first_creature.strength
                return

            # if both commanders have no creatures left, battle ends
            if self.first_creature is None and other.first_creature is None:
                return
    def display(self):
        current = self.first_creature
        result = f"Commander(hit_points={self.hit_points})"

        if current is None:
            return result + "\n  No creatures"

        while current:
            result += f"\n  Creature(strength={current.strength}, defense={current.defense})"
            current = current.next_creature

        return result

if __name__ == "__main__":

    # Commander 1 creature chain
    c1 = Creature(6, 5, Creature(4, 3))

    # Commander 2 creature chain
    c2 = Creature(5, 4, Creature(2, 2))

    commander1 = Commander()
    commander2 = Commander()

    commander1.addCreature(c1)
    commander2.addCreature(c2)

    print("Before battle:")
    print(commander1.display())
    print(commander2.display())

    commander1.battle(commander2)

    print("\nAfter battle:")
    print(commander1.display())
    print(commander2.display())

